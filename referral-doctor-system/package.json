{
  "name": "referral-doctor-system",
  "version": "1.0.0",
  "description": "Production-level Referral Doctor Management System",
  "main": "electron/main.js",
  "homepage": "./",
  "engines": {
    "node": ">=18 <21"
  },
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"wait-on http://localhost:5173 && npm run electron\"",
    "vite": "vite",
    "electron": "electron .",
    "build": "vite build && electron-builder",
    "build:vite": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "crypto-js": "^4.1.1",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.referraldoctor.system",
    "productName": "Referral Doctor Management System",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "public"
    }
  }
}
